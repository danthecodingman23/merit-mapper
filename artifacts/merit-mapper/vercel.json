{
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/match.js": { "maxDuration": 60 },
    "api/scholarships/save.js": { "maxDuration": 10 },
    "api/scholarships/saved.js": { "maxDuration": 10 },
    "api/scholarships/unsave.js": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
